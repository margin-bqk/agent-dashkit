# Agent DashKit Configuration
# Copy this file to .env and fill in your values

# API Key for agent authentication (auto-generated if empty)
DASHKIT_API_KEY=

# Dashboard password for frontend viewers (optional - leave empty for no password)
DASHKIT_PASSWORD=

# Server port (default: 8000)
DASHKIT_PORT=8000

# Database file path
DASHKIT_DB_PATH=dashkit.db
